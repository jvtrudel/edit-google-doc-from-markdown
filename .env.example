# Clé API Anthropic (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...

# Chemin vers le fichier JSON de clé de compte de service Google
# (à obtenir depuis Google Cloud Console > IAM > Comptes de service)
GOOGLE_SERVICE_ACCOUNT_KEY=service-account.json

# Niveau de log (optionnel: error, warn, info, debug, trace)
RUST_LOG=edit_google_doc=info
