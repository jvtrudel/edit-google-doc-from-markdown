#!/bin/bash
# nou — CLI pour le projet edit-google-doc-from-markdown
# Prototype : commandes non fonctionnelles, documentation uniquement
set -euo pipefail

VERSION="0.2.0"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
BINARY="$PROJECT_DIR/target/release/edit-google-doc"

# Couleurs
RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
NC='\033[0m'

stub() {
    echo -e "${YELLOW}⚠️  Non implémenté — prévu pour une prochaine version${NC}"
    echo -e "   Fonctionnalité : $1"
}

# ─── Commandes principales ───────────────────────────────────────────

# Vérifie que le binaire est compilé, sinon propose de le compiler
ensure_binary() {
    if [ ! -f "$BINARY" ]; then
        # Essayer le binaire debug
        local debug_binary="$PROJECT_DIR/target/debug/edit-google-doc"
        if [ -f "$debug_binary" ]; then
            BINARY="$debug_binary"
            return 0
        fi
        echo -e "${YELLOW}Le binaire n'est pas compilé. Compilation en cours...${NC}"
        (cd "$PROJECT_DIR" && cargo build --release) || {
            echo -e "${RED}Erreur de compilation${NC}"
            exit 1
        }
    fi
}

cmd_help() {
    echo -e "${BOLD}nou${NC} — CLI pour edit-google-doc-from-markdown (v${VERSION})"
    echo ""
    echo -e "${BOLD}USAGE${NC}"
    echo "    nou <commande> [arguments]"
    echo ""
    echo -e "${BOLD}COMMANDES DE SYNCHRONISATION${NC}"
    echo "    pull [fichier.md] [--doc-id ID] [-f]   Récupérer un Google Doc en Markdown"
    echo "    push <fichier.md> [--doc-id ID] [-f]   Publier un Markdown vers Google Doc"
    echo "    sync-status [fichier.md]               État de synchronisation d'un fichier"
    echo ""
    echo -e "${BOLD}COMMANDES UTILISATEUR${NC}"
    echo "    help                    Affiche cette aide"
    echo "    status                  État du projet (branche, phase, ticket)"
    echo ""
    echo -e "${BOLD}COMMANDES DE DÉVELOPPEMENT${NC}"
    echo "    dev init [name]         Créer une nouvelle ronde d'amélioration"
    echo "    dev ticket              Afficher le ticket de la ronde courante"
    echo "    dev phase               Afficher la phase courante"
    echo "    dev advance [--dry-run]  Commiter et passer à la phase suivante"
    echo "    dev done [--dry-run]     Merger dans main, tagger et pousser"
    echo "    dev log \"description\"   Écrire une entrée de log"
    echo ""
    echo -e "${BOLD}COMMANDES DE DOCUMENTATION${NC}"
    echo "    doc needs               Lister les besoins"
    echo "    doc requirements        Lister les requis"
    echo "    doc features            Lister les fonctionnalités"
}

cmd_status() {
    echo -e "${BOLD}État du projet${NC}"
    echo ""

    # Branche courante
    local branch
    branch=$(git branch --show-current 2>/dev/null || echo "inconnue")
    echo -e "  ${CYAN}Branche :${NC} $branch"

    # Dernier répertoire d'historique
    local latest_history
    latest_history=$(ls -d "$SCRIPT_DIR"/.dev/history/*/ 2>/dev/null | sort | tail -1 || echo "")
    if [ -n "$latest_history" ]; then
        local ronde_name
        ronde_name=$(basename "$latest_history")
        echo -e "  ${CYAN}Ronde :${NC}   $ronde_name"

        # Ticket
        if [ -f "$latest_history/ticket.md" ]; then
            local phase
            phase=$(grep -i "phase" "$latest_history/ticket.md" | head -1 || echo "inconnue")
            echo -e "  ${CYAN}Phase :${NC}   $phase"
        fi
    else
        echo -e "  ${YELLOW}Aucune ronde d'amélioration en cours${NC}"
    fi
}

cmd_run() {
    local instruction="${1:-}"
    if [ -z "$instruction" ]; then
        echo -e "${RED}Erreur : fournir une instruction${NC}"
        echo "Usage : nou run \"votre instruction\""
        exit 1
    fi
    stub "Lancer l'agent IA avec : $instruction"
}

# ─── Commandes dev ───────────────────────────────────────────────────

cmd_dev_init() {
    local name="${1:-}"
    if [ -z "$name" ]; then
        echo -e "${RED}Erreur : fournir un nom pour la ronde${NC}"
        echo "Usage : nou dev init <nom>"
        exit 1
    fi
    stub "Créer une nouvelle ronde d'amélioration : $name"
}

cmd_dev_ticket() {
    local latest_history
    latest_history=$(ls -d "$SCRIPT_DIR"/.dev/history/*/ 2>/dev/null | sort | tail -1 || echo "")
    if [ -n "$latest_history" ] && [ -f "$latest_history/ticket.md" ]; then
        cat "$latest_history/ticket.md"
    else
        echo -e "${YELLOW}Aucun ticket trouvé${NC}"
    fi
}

cmd_dev_phase() {
    local latest_history
    latest_history=$(ls -d "$SCRIPT_DIR"/.dev/history/*/ 2>/dev/null | sort | tail -1 || echo "")
    if [ -n "$latest_history" ] && [ -f "$latest_history/ticket.md" ]; then
        grep -i "phase" "$latest_history/ticket.md" | head -1 || echo "Phase inconnue"
    else
        echo -e "${YELLOW}Aucune ronde en cours${NC}"
    fi
}

cmd_dev_log() {
    local description="${1:-}"
    if [ -z "$description" ]; then
        echo -e "${RED}Erreur : fournir une description${NC}"
        echo "Usage : nou dev log \"description\""
        exit 1
    fi
    stub "Écrire une entrée de log : $description"
}

# Phases du cycle de développement
PHASES=(
    "1 — Définir la portée"
    "2 — Planifier l'amélioration"
    "3 — Implémenter l'amélioration"
    "4 — Vérifier l'amélioration"
    "5 — Consolider l'amélioration"
    "6 — Publier l'amélioration"
)

# Extraire le numéro de phase depuis le ticket
get_current_phase_num() {
    local ticket="$1"
    grep -oP '\*\*Phase\s*:\*\*\s*\K[0-9]+' "$ticket" 2>/dev/null || echo "0"
}

# Trouver le répertoire de la ronde courante
get_current_round_dir() {
    ls -d "$PROJECT_DIR"/.dev/history/*/ 2>/dev/null | sort | tail -1 || echo ""
}

cmd_dev_advance() {
    local dry_run=false
    for arg in "$@"; do
        case "$arg" in
            --dry-run) dry_run=true ;;
        esac
    done

    # 1. Trouver la ronde courante
    local round_dir
    round_dir=$(get_current_round_dir)
    if [ -z "$round_dir" ] || [ ! -f "$round_dir/ticket.md" ]; then
        echo -e "${RED}Erreur : aucune ronde d'amélioration en cours${NC}"
        exit 1
    fi

    local round_name
    round_name=$(basename "$round_dir")
    local ticket="$round_dir/ticket.md"

    # 2. Détecter la branche
    local branch
    branch=$(git -C "$PROJECT_DIR" branch --show-current 2>/dev/null || echo "inconnue")

    # 3. Détecter la phase courante
    local phase_num
    phase_num=$(get_current_phase_num "$ticket")
    if [ "$phase_num" -eq 0 ]; then
        echo -e "${RED}Erreur : impossible de détecter la phase dans le ticket${NC}"
        exit 1
    fi

    local current_phase="${PHASES[$((phase_num - 1))]}"

    # 4. Déterminer la prochaine phase
    local next_phase_num=$((phase_num + 1))
    local next_phase
    local is_final=false
    if [ "$next_phase_num" -gt 6 ]; then
        next_phase="Terminée"
        is_final=true
    else
        next_phase="${PHASES[$((next_phase_num - 1))]}"
    fi

    # 5. Construire le message de commit
    local commit_msg
    if [ "$is_final" = true ]; then
        commit_msg="chore(${round_name}): fin de l'amélioration — phase ${current_phase} terminée"
    else
        commit_msg="chore(${round_name}): passage phase ${current_phase} → ${next_phase}"
    fi

    # 6. Vérifier s'il y a des modifications
    local has_changes
    has_changes=$(git -C "$PROJECT_DIR" status --porcelain 2>/dev/null | wc -l)

    # 7. Afficher le résumé
    echo -e "${BOLD}nou dev advance${NC}"
    echo ""
    echo -e "  ${CYAN}Ronde :${NC}          $round_name"
    echo -e "  ${CYAN}Branche :${NC}        $branch"
    echo -e "  ${CYAN}Phase courante :${NC} $current_phase"
    if [ "$is_final" = true ]; then
        echo -e "  ${GREEN}Prochaine :${NC}      Amélioration terminée"
    else
        echo -e "  ${CYAN}Prochaine :${NC}      $next_phase"
    fi
    echo -e "  ${CYAN}Modifications :${NC}  $has_changes fichier(s)"
    echo ""

    if [ "$dry_run" = true ]; then
        echo -e "${YELLOW}Mode dry-run — commandes qui seraient exécutées :${NC}"
        echo ""
        if [ "$has_changes" -gt 0 ]; then
            echo "  git -C $PROJECT_DIR add -A"
            echo "  git -C $PROJECT_DIR commit -m \"$commit_msg\""
        else
            echo "  (aucune modification à commiter)"
        fi
        if [ "$is_final" = false ]; then
            echo "  # Mise à jour du ticket : Phase → $next_phase"
            echo "  sed -i 's/^\\(\\*\\*Phase\\s*:\\*\\*\\).*/\\1 $next_phase/' $ticket"
        fi
        echo ""
        echo -e "${YELLOW}Aucune action effectuée.${NC}"
        return 0
    fi

    # 8. Exécuter
    if [ "$has_changes" -gt 0 ]; then
        git -C "$PROJECT_DIR" add -A
        git -C "$PROJECT_DIR" commit -m "$commit_msg"
        echo ""
    else
        echo -e "  ${YELLOW}Aucune modification à commiter${NC}"
        echo ""
    fi

    # 9. Mettre à jour le ticket (sauf si terminée)
    if [ "$is_final" = false ]; then
        sed -i "s/^\(\*\*Phase\s*:\*\*\).*/\1 ${next_phase}/" "$ticket"
        echo -e "  ${GREEN}✔${NC} Ticket mis à jour → Phase $next_phase"
        # Commiter la mise à jour du ticket
        git -C "$PROJECT_DIR" add "$ticket"
        git -C "$PROJECT_DIR" commit -m "chore(${round_name}): ticket → phase ${next_phase}" --allow-empty
    else
        echo -e "  ${GREEN}✔${NC} Amélioration $round_name terminée"
    fi
}

cmd_dev_done() {
    local dry_run=false
    for arg in "$@"; do
        case "$arg" in
            --dry-run) dry_run=true ;;
        esac
    done

    # 1. Ronde courante
    local round_dir
    round_dir=$(get_current_round_dir)
    if [ -z "$round_dir" ] || [ ! -f "$round_dir/ticket.md" ]; then
        echo -e "${RED}Erreur : aucune ronde d'amélioration en cours${NC}"
        exit 1
    fi
    local round_name
    round_name=$(basename "$round_dir")

    # 2. Branche courante
    local branch
    branch=$(git -C "$PROJECT_DIR" branch --show-current 2>/dev/null || echo "")
    if [ -z "$branch" ] || [ "$branch" = "main" ]; then
        echo -e "${RED}Erreur : déjà sur main ou branche inconnue${NC}"
        exit 1
    fi

    # 3. Lire la version depuis Cargo.toml
    local version
    version=$(grep '^version' "$PROJECT_DIR/Cargo.toml" | head -1 | sed 's/version = "\(.*\)"/\1/')
    if [ -z "$version" ]; then
        echo -e "${RED}Erreur : impossible de lire la version dans Cargo.toml${NC}"
        exit 1
    fi
    local tag="v${version}"

    # 4. Vérifier les modifications non commitées
    local has_changes
    has_changes=$(git -C "$PROJECT_DIR" status --porcelain 2>/dev/null | wc -l)

    # 5. Résumé
    echo -e "${BOLD}nou dev done${NC}"
    echo ""
    echo -e "  ${CYAN}Ronde :${NC}    $round_name"
    echo -e "  ${CYAN}Branche :${NC}  $branch → main"
    echo -e "  ${CYAN}Version :${NC}  $tag"
    echo -e "  ${CYAN}Modifs :${NC}   $has_changes fichier(s) non commités"
    echo ""

    if [ "$dry_run" = true ]; then
        echo -e "${YELLOW}Mode dry-run — commandes qui seraient exécutées :${NC}"
        echo ""
        if [ "$has_changes" -gt 0 ]; then
            echo "  git -C $PROJECT_DIR add -A"
            echo "  git -C $PROJECT_DIR commit -m \"chore(${round_name}): consolidation avant publication\""
        fi
        echo "  git -C $PROJECT_DIR checkout main"
        echo "  git -C $PROJECT_DIR merge --no-ff $branch -m \"feat: merge ${round_name} → main ($tag)\""
        echo "  git -C $PROJECT_DIR tag $tag"
        echo "  git -C $PROJECT_DIR push origin main"
        echo "  git -C $PROJECT_DIR push origin $tag"
        echo ""
        echo -e "${YELLOW}Aucune action effectuée.${NC}"
        return 0
    fi

    # 6. Commiter les modifications restantes
    if [ "$has_changes" -gt 0 ]; then
        echo -e "  ${CYAN}Commit des modifications restantes...${NC}"
        git -C "$PROJECT_DIR" add -A
        git -C "$PROJECT_DIR" commit -m "chore(${round_name}): consolidation avant publication"
        echo ""
    fi

    # 7. Merge dans main
    echo -e "  ${CYAN}Merge dans main...${NC}"
    git -C "$PROJECT_DIR" checkout main
    git -C "$PROJECT_DIR" merge --no-ff "$branch" -m "feat: merge ${round_name} → main ($tag)"
    echo ""

    # 8. Tag de version
    echo -e "  ${CYAN}Tag $tag...${NC}"
    git -C "$PROJECT_DIR" tag "$tag"
    echo ""

    # 9. Push
    echo -e "  ${CYAN}Push...${NC}"
    git -C "$PROJECT_DIR" push origin main
    git -C "$PROJECT_DIR" push origin "$tag"
    echo ""

    echo -e "${GREEN}✔ Ronde $round_name publiée en $tag${NC}"
}

# ─── Commandes doc ───────────────────────────────────────────────────

cmd_doc_needs() {
    echo -e "${BOLD}Besoins utilisateurs${NC}"
    local count
    count=$(find "$SCRIPT_DIR"/.dev/needs -name "*.md" ! -name "README.md" ! -name "_template.md" 2>/dev/null | wc -l)
    if [ "$count" -gt 0 ]; then
        find "$SCRIPT_DIR"/.dev/needs -name "*.md" ! -name "README.md" ! -name "_template.md" -exec basename {} \; | sort
    else
        echo -e "  ${YELLOW}Aucun besoin documenté${NC}"
    fi
}

cmd_doc_requirements() {
    echo -e "${BOLD}Requis${NC}"
    local count
    count=$(find "$SCRIPT_DIR"/.dev/requirements -name "*.md" ! -name "README.md" ! -name "_template.md" 2>/dev/null | wc -l)
    if [ "$count" -gt 0 ]; then
        find "$SCRIPT_DIR"/.dev/requirements -name "*.md" ! -name "README.md" ! -name "_template.md" -exec basename {} \; | sort
    else
        echo -e "  ${YELLOW}Aucun requis documenté${NC}"
    fi
}

cmd_doc_features() {
    echo -e "${BOLD}Fonctionnalités${NC}"
    local count
    count=$(find "$SCRIPT_DIR"/.dev/features -name "*.md" ! -name "README.md" ! -name "_template.md" 2>/dev/null | wc -l)
    if [ "$count" -gt 0 ]; then
        find "$SCRIPT_DIR"/.dev/features -name "*.md" ! -name "README.md" ! -name "_template.md" -exec basename {} \; | sort
    else
        echo -e "  ${YELLOW}Aucune fonctionnalité documentée${NC}"
    fi
}

# ─── Routeur ─────────────────────────────────────────────────────────

main() {
    local cmd="${1:-help}"
    shift || true

    case "$cmd" in
        help|-h|--help)
            cmd_help
            ;;
        pull)
            ensure_binary
            "$BINARY" pull "$@"
            ;;
        push)
            ensure_binary
            "$BINARY" push "$@"
            ;;
        sync-status)
            ensure_binary
            "$BINARY" status "$@"
            ;;
        status)
            cmd_status
            ;;
        run)
            cmd_run "$@"
            ;;
        dev)
            local subcmd="${1:-}"
            shift || true
            case "$subcmd" in
                init)    cmd_dev_init "$@" ;;
                ticket)  cmd_dev_ticket ;;
                phase)   cmd_dev_phase ;;
                advance) cmd_dev_advance "$@" ;;
                done)    cmd_dev_done "$@" ;;
                log)     cmd_dev_log "$@" ;;
                *)
                    echo -e "${RED}Commande dev inconnue : $subcmd${NC}"
                    echo "Commandes disponibles : init, ticket, phase, advance, done, log"
                    exit 1
                    ;;
            esac
            ;;
        doc)
            local subcmd="${1:-}"
            shift || true
            case "$subcmd" in
                needs)        cmd_doc_needs ;;
                requirements) cmd_doc_requirements ;;
                features)     cmd_doc_features ;;
                *)
                    echo -e "${RED}Commande doc inconnue : $subcmd${NC}"
                    echo "Commandes disponibles : needs, requirements, features"
                    exit 1
                    ;;
            esac
            ;;
        version|-v|--version)
            echo "nou v${VERSION}"
            ;;
        *)
            echo -e "${RED}Commande inconnue : $cmd${NC}"
            echo "Tapez 'nou help' pour l'aide."
            exit 1
            ;;
    esac
}

main "$@"
